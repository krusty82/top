	<Rule>
        &maxscale_zoom4;
        &minscale_zoom4;
        <Filter>[place] = 'country'</Filter>
        <TextSymbolizer fontset-name="sans-condensed-bold"
                        size="12"
                        fill="black"
                        opacity="0.5"       
                        halo-radius="1.5"
                        halo-fill="white"
                        halo-opacity="0.7"
                        wrap-width="45"
                        placement="point"
                        allow-overlap="false"
						placement-type="simple"
  						placements="N,NW,W,SW,S,SE,E,NE,10,8"
                        avoid-edges="false"
                        text-transform="uppercase">
            [name]
        </TextSymbolizer>
    </Rule>
    <Rule>
        &maxscale_zoom5;
        &minscale_zoom5;
        <Filter>[place] = 'country'</Filter>
        <TextSymbolizer fontset-name="sans-condensed-bold"
                        size="15"
                        fill="black"
                        opacity="0.5"      
                        halo-radius="1.5"
                        halo-fill="white"
                        halo-opacity="0.7"
                        wrap-width="60"
                        placement="point"
                        allow-overlap="false"
						placement-type="simple"
  						placements="N,NW,W,SW,S,SE,E,NE,10,8"
                        avoid-edges="false"
                        text-transform="uppercase">
            [name]
        </TextSymbolizer>
    </Rule>


