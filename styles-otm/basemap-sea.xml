
<Style name="searelief-5000">
	<Rule>
		&maxscale_zoom1;
		&minscale_zoom4;
		<RasterSymbolizer opacity="1" scaling="bilinear" />
	</Rule>
</Style>
<Layer name="searelief-5000">
	<StyleName>searelief-5000</StyleName>
	<Datasource>
		<Parameter name="type">gdal</Parameter>
		<Parameter name="file">/mnt/data/srtm/searelief-5000.tif</Parameter>
		<Parameter name="format">tiff</Parameter>
	</Datasource>
</Layer>

