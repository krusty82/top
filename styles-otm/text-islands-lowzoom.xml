<Style name="text-islands-lowzoom">
	<Rule>
        &maxscale_zoom6;
        &minscale_zoom6;
        <Filter>[place] = 'island' and [way_area] &gt; 1E11</Filter>
        <TextSymbolizer fontset-name="sans-condensed-bold"
                        size="20"
                        fill="black"
                        opacity="0.5"       
                        halo-radius="1.3"
                        halo-fill="white"
                        halo-opacity="0.7"
                        wrap-width="65"
                        placement="point"
                        allow-overlap="true"
						placement-type="simple"
  						placements="N,NW,W,SW,S,SE,E,NE,10,8"
                        avoid-edges="false"
                        >
            [name]
        </TextSymbolizer>
    </Rule>
