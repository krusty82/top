<Style name="hillshade-5000">
	<Rule>
		&maxscale_zoom1;
		&minscale_zoom3;
		<RasterSymbolizer comp-op="grain-merge" opacity="0.83" scaling="bicubic" />
	</Rule>
</Style>
<Layer name="hillshade-5000">
	<StyleName>hillshade-5000</StyleName>
	<Datasource>
		<Parameter name="type">gdal</Parameter>
		<Parameter name="file">/mnt/data/srtm/hillshade-5000.tif</Parameter>
		<Parameter name="format">tiff</Parameter>
	</Datasource>
</Layer>

