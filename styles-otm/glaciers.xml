<Style name="glaciers">
	
	<Rule>
		&maxscale_zoom0;
		&minscale_zoom10;
		<Filter>([natural] = 'glacier')</Filter>
		<PolygonSymbolizer fill="#d0f8ff" fill-opacity="0.9"/>
	</Rule>
	<Rule>
		&maxscale_zoom11;
		&minscale_zoom17;
		<Filter>([natural] = 'glacier')</Filter>
		<PolygonSymbolizer fill="#d0f8ff" fill-opacity="0.8"/>
	</Rule>
</Style>

	<Layer name="glaciers">
        <StyleName>glaciers</StyleName>
        <Datasource>
            <Parameter name="table">(SELECT way,landuse,"natural",leaf_type,amenity,building,power FROM planet_osm_polygon WHERE 
                ("natural" = 'glacier')) AS
                landuse
            </Parameter>
            <Parameter name="dbname">gis</Parameter>
            &postgis-settings;
        </Datasource>
    </Layer>
<Style name="antarctica">
        <Rule>
                &maxscale_zoom0;
                &minscale_zoom17;
			<PolygonSymbolizer 
				fill="#d0f8ff"
				fill-opacity="0.9"
				gamma="0.5"/>
        </Rule>
</Style>

<Layer name="antarctica">
<StyleName>antarctica</StyleName>
<Datasource>
        <Parameter name="type">shape</Parameter>
        <Parameter name="file">/mnt/data/antarctica-icesheet-polygons-3857/icesheet_polygons</Parameter>
</Datasource>
</Layer>
