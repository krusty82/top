<Style name="text-seas">
 
<Rule>
                &maxscale_zoom5;
                &minscale_zoom6;
                <TextSymbolizer fontset-name="sans-oblique" fill="#2020ff" halo-radius="1" halo-fill="rgba(255,255,255,0.8)" wrap-width="100" max-char-angle-delta="0" smooth="0.5"  placement="point" size="12">[nameen]
        </TextSymbolizer>
 </Rule>
<Rule>
                &maxscale_zoom7;
                &minscale_zoom10;
                <TextSymbolizer fontset-name="sans-oblique" fill="#2020ff" halo-radius="1" halo-fill="rgba(255,255,255,0.8)" wrap-width="100" max-char-angle-delta="0" smooth="0.5"  placement="point" size="16">[nameen]
        </TextSymbolizer>
 </Rule>
</Style>
