<Style name="symbols-saddle">
	<Rule>
		&maxscale_zoom12;
		&minscale_zoom12;
		<Filter>([natural] = 'saddle' or [mountain_pass] = 'yes') and [has_way]</Filter>
		<PointSymbolizer allow-overlap="true" file="symbols-otm/saddle-15.svg" transform="rotate([direction]) scale(0.9)" />
	</Rule>
	<Rule>
		&maxscale_zoom13;
		&minscale_zoom13;
		<Filter>([natural] = 'saddle' or [mountain_pass] = 'yes') and [has_way]</Filter>
		<PointSymbolizer allow-overlap="true" file="symbols-otm/saddle-15.svg" transform="rotate([direction]) scale(1.2)" />
	</Rule>
	<Rule>
		&maxscale_zoom14;
		&minscale_zoom14;
		<Filter>([natural] = 'saddle' or [mountain_pass] = 'yes') and [has_way]</Filter>
		<PointSymbolizer allow-overlap="true" file="symbols-otm/saddle-15.svg" transform="rotate([direction]) scale(1.5)" />
	</Rule>
    <Rule>
		&maxscale_zoom13;
		&minscale_zoom14;
		<Filter>([natural] = 'saddle'  or [mountain_pass] = 'yes') and [has_way] and not ([name] = null)</Filter>
		<TextSymbolizer fontset-name="sans-oblique" size="10" fill="black" margin="1" halo-radius="1.5" halo-fill="rgba(255,255,255,0.8)" placement="point" dy="17" wrap-width="100">[name]+"\n"+[ele]</TextSymbolizer>
	</Rule>
    <Rule>
		&maxscale_zoom14;
		&minscale_zoom14;
		<Filter>([natural] = 'saddle' or [mountain_pass] = 'yes')  and [has_way] and ([name] = null)</Filter>
		<TextSymbolizer fontset-name="sans-oblique" size="9" fill="black" margin="1" halo-radius="1.5" halo-fill="rgba(255,255,255,0.8)" placement="point" dy="17" wrap-width="100">[ele]</TextSymbolizer>
	</Rule>

	<Rule>
		&maxscale_zoom15;
		&minscale_zoom15;
		<Filter>([natural] = 'saddle' or [mountain_pass] = 'yes') and [has_way]</Filter>
        <PointSymbolizer allow-overlap="true" file="symbols-otm/saddle-15.svg" transform="rotate([direction]) scale(1.8)" />
	</Rule>
	<Rule>
		&maxscale_zoom16;
		&minscale_zoom17;
		<Filter>([natural] = 'saddle' or [mountain_pass] = 'yes') and [has_way]</Filter>
        <PointSymbolizer allow-overlap="true" file="symbols-otm/saddle-15.svg" transform="rotate([direction]) scale(2.2)" />
	</Rule>
    <Rule>
		&maxscale_zoom15;
		&minscale_zoom17;
		<Filter>([natural] = 'saddle' or [mountain_pass] = 'yes') and not ([name] = null)</Filter>
		<TextSymbolizer allow-overlap="true" fontset-name="sans-oblique" size="11" fill="black" margin="1" halo-radius="1.5" halo-fill="rgba(255,255,255,0.8)" placement="point" dy="22" wrap-width="100">[name]+"\n"+[ele]</TextSymbolizer>
	</Rule>
	<Rule>
		&maxscale_zoom15;
		&minscale_zoom17;
		<Filter>([natural] = 'saddle' or [mountain_pass] = 'yes') and ([name] = null)</Filter>
		<TextSymbolizer allow-overlap="true" fontset-name="sans-oblique" size="9" fill="black" margin="1" halo-radius="1.5" halo-fill="rgba(255,255,255,0.8)" placement="point" dy="22" wrap-width="100">[ele]</TextSymbolizer>
	</Rule>

	<Rule>
		&maxscale_zoom13;
		&minscale_zoom14;
		<Filter>([natural] = 'col' or [natural] = 'notch' or [natural] = 'saddle') and not [has_way]</Filter>
		<PointSymbolizer allow-overlap="true" file="symbols-otm/saddle-10.svg" transform="rotate([direction]) scale(1)" />
	</Rule>
	<Rule>
		&maxscale_zoom15;
		&minscale_zoom17;
		<Filter>([natural] = 'col' or [natural] = 'notch' or [natural] = 'saddle') and not [has_way]</Filter>
		<PointSymbolizer allow-overlap="true" file="symbols-otm/saddle-15.svg" transform="rotate([direction]) scale(1)" />
	</Rule>
	<Rule>
		&maxscale_zoom15;
		&minscale_zoom17;
		<Filter>([natural] = 'col' or [natural] = 'notch') and not ([name] = null)</Filter>
		<TextSymbolizer fontset-name="sans-oblique" size="9" fill="black" margin="1" halo-radius="1.5" halo-fill="rgba(255,255,255,0.8)" placement="point" dy="8" wrap-width="100">[name]+"\n"+[ele]</TextSymbolizer>
	</Rule>
	<Rule>
		&maxscale_zoom15;
		&minscale_zoom17;
		<Filter>([natural] = 'col' or [natural] = 'notch') and ([name] = null)</Filter>
		<TextSymbolizer fontset-name="sans-oblique" size="9" fill="black" margin="1" halo-radius="1.5" halo-fill="rgba(255,255,255,0.8)" placement="point" dy="8" wrap-width="100">[ele]</TextSymbolizer>
	</Rule>

</Style>
